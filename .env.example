# LLM — Groq is recommended (free, fast, no GPU needed)
GROQ_API_KEY=gsk_...                # free at console.groq.com
OPENAI_API_KEY=sk-...               # optional fallback
OLLAMA_BASE_URL=http://localhost:11434

# Notifications
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# Enrichment (all free tiers)
TAVILY_API_KEY=...                  # free 1000 req/mo
HUNTER_API_KEY=...                  # free 25 req/mo

# Database
SQLITE_DB_PATH=./data/huntflow.db
CHROMADB_PATH=./data/chromadb

# Behavior
LOG_LEVEL=INFO
LLM_PROVIDER=groq
LLM_MODEL=llama3-8b-8192
SCRAPE_DELAY_MIN=2.0
SCRAPE_DELAY_MAX=5.0
MAX_JOBS_PER_RUN=200
MIN_JOB_SCORE=30

# LinkedIn (see PROMPT 5B for full strategy — read before using)
# Mode 1 (recommended, no login): LinkedIn public jobs RSS — no account needed
# Mode 2 (optional, session-based): paste your li_at cookie for authenticated scraping
# Mode 3 (optional, API): RapidAPI LinkedIn Jobs Search — free tier 100 req/mo
LINKEDIN_MODE=rss                   # rss | cookie | rapidapi
LINKEDIN_LI_AT_COOKIE=             # your li_at session cookie (Mode 2 only)
RAPIDAPI_KEY=                       # RapidAPI key (Mode 3 only)
LINKEDIN_SCRAPE_DELAY=8.0           # longer delays — LinkedIn is aggressive
LINKEDIN_MAX_JOBS_PER_RUN=50        # conservative cap to avoid blocks
